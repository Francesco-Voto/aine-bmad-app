{
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "npm run typecheck --workspace=client && npm run typecheck --workspace=server",
    "test:client": "npm run test --workspace=client",
    "test:server": "npm run test --workspace=server",
    "test": "npm run test:client && npm run test:server",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:coverage": "npm run test:coverage --workspace=client",
    "test:all": "npm run test && npm run test:e2e",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^9.39.4",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}